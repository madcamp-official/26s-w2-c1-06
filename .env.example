# 이 파일의 키들은 전부 dev 전용이다 — 패키징된(배포된) 빌드는 이 값들을 안 읽고
# createAIProvider.ts의 PACKAGED_PROXY_URL/TOKEN을 거쳐 Cloudflare Worker 프록시로
# OpenAI를 호출한다(worker/ 참조). 진짜 OpenAI 키를 배포본에 절대 넣지 말 것.

# OpenAI를 우선 사용한다 — 이 값이 있으면 아래 Gemini 키는 안 읽는다.
OPENAI_API_KEY=

# OPENAI_API_KEY가 없을 때만 쓰이는 폴백. 서로 다른 계정의 키 두 개를 넣으면
# 라운드로빈/429 폴백으로 무료 티어 RPM 예산을 사실상 2배로 쓸 수 있다.
GEMINI_KEY_A=
GEMINI_KEY_B=

# 셋 다 비워두면 네트워크 호출 없는 MockAIProvider로 자동 대체된다(오프라인 개발용).
